<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Owners</h1>
    <% if policy(Owner).new? %>
      <%= link_to "New Owner", new_owner_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <table class="table table-striped">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @owners.each do |owner| %>
        <tr>
          <td><%= owner.first_name %> <%= owner.last_name %></td>
          <td><%= owner.email %></td>
          <td class="d-flex gap-2">
            <%= link_to "Show", owner, class: "btn btn-sm btn-info" %>
            <% if policy(owner).edit? %>
              <%= link_to "Edit", edit_owner_path(owner), class: "btn btn-sm btn-warning" %>
            <% end %>
            <% if policy(owner).destroy? %>
              <%= button_to "Delete", owner, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
