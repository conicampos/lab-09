<div class="container mt-4">
  <div class="card shadow">
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
      <h2 class="mb-0">Veterinarian Profile</h2>
      <div>
        <%= link_to "Edit Vet", edit_vet_path(@vet), class: "btn btn-light btn-sm" %>
      </div>
    </div>
    <div class="card-body">
      <div class="row mb-3">
        <div class="col-sm-3 fw-bold">Name:</div>
        <div class="col-sm-9">Dr. <%= @vet.first_name %> <%= @vet.last_name %></div>
      </div>
      <div class="row mb-3">
        <div class="col-sm-3 fw-bold">Specialization:</div>
        <div class="col-sm-9"><span class="badge bg-info text-dark"><%= @vet.specialization %></span></div>
      </div>
      <div class="row mb-3">
        <div class="col-sm-3 fw-bold">Email:</div>
        <div class="col-sm-9"><%= @vet.email %></div>
      </div>

      <hr>
      <h4>Scheduled Appointments</h4>
      <% if @vet.appointments.any? %>
        <table class="table table-sm">
          <thead>
            <tr>
              <th>Date</th>
              <th>Pet</th>
              <th>Reason</th>
            </tr>
          </thead>
          <tbody>
            <% @vet.appointments.each do |app| %>
              <tr>
                <td><%= app.date.strftime("%d/%m/%Y %H:%M") %></td>
                <td><%= app.pet.name %></td>
                <td><%= app.reason %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No appointments assigned to this vet.</p>
      <% end %>
    </div>
    <div class="card-footer d-flex justify-content-between">
      <%= link_to "Back to Vets", vets_path, class: "btn btn-secondary" %>
      <%= button_to "Delete Vet", @vet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
    </div>
  </div>
</div>
