<%= form_with(model: vet) do |f| %>
  <%= render 'shared/error_messages', object: vet %>
  <div class="mb-3"><%= f.label :first_name, class: "form-label" %><%= f.text_field :first_name, class: "form-control" %></div>
  <div class="mb-3"><%= f.label :last_name, class: "form-label" %><%= f.text_field :last_name, class: "form-control" %></div>
  <div class="mb-3"><%= f.label :email, class: "form-label" %><%= f.email_field :email, class: "form-control" %></div>
  <div class="mb-3"><%= f.label :specialization, class: "form-label" %><%= f.text_field :specialization, class: "form-control" %></div>
  <%= f.submit class: "btn btn-primary" %>
<% end %>