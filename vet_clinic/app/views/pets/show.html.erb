<div class="container mt-4">
  <div class="card shadow">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
      <h2 class="mb-0">Pet Profile: <%= @pet.name %></h2>
      <div>
        <% if policy(@pet).edit? %>
          <%= link_to "Edit Pet", edit_pet_path(@pet), class: "btn btn-light btn-sm" %>
        <% end %>
      </div>
    </div>
    <div class="card-body">
      <%# --- SECCIÓN DE FOTO (PASO A.6) --- %>
      <div class="row mb-4">
        <div class="col-12 text-center">
          <% if @pet.photo.attached? %>
            <%= image_tag @pet.photo, class: "img-fluid rounded shadow-sm border", style: "max-width: 300px;" %>
          <% else %>
            <div class="d-inline-block bg-light border rounded p-5 text-muted">
              <i class="bi bi-camera" style="font-size: 2rem;"></i><br>
              No photo available
            </div>
          <% end %>
        </div>
      </div>
      <%# ---------------------------------- %>

      <div class="row mb-3">
        <div class="col-sm-3 fw-bold">Species / Breed:</div>
        <div class="col-sm-9"><%= @pet.species.capitalize %> / <%= @pet.breed %></div>
      </div>
      <div class="row mb-3">
        <div class="col-sm-3 fw-bold">Owner:</div>
        <div class="col-sm-9"><%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %></div>
      </div>

      <hr>
      <div class="row">
        <div class="col-md-6">
          <h4 class="text-primary">Upcoming Appointments</h4>
          <ul class="list-group mb-3">
            <% if @pet.appointments_upcoming.any? %>
              <% @pet.appointments_upcoming.each do |app| %>
                <li class="list-group-item"><%= app.date.strftime("%d/%m/%Y") %> - <%= app.reason %></li>
              <% end %>
            <% else %>
              <li class="list-group-item text-muted small">No upcoming appointments</li>
            <% end %>
          </ul>
        </div>
        <div class="col-md-6">
          <h4 class="text-muted">Past Appointments</h4>
          <ul class="list-group">
            <% if @pet.appointments_past.any? %>
              <% @pet.appointments_past.each do |app| %>
                <li class="list-group-item list-group-item-light"><%= app.date.strftime("%d/%m/%Y") %></li>
              <% end %>
            <% else %>
              <li class="list-group-item text-muted small">No past appointments</li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
      <%= link_to "Back to Pets", pets_path, class: "btn btn-secondary" %>
      <% if policy(@pet).destroy? %>
        <%= button_to "Delete Pet", @pet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
      <% end %>
    </div>
  </div>
</div>
