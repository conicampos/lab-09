<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Pets</h1>
    <%= link_to "New Pet", new_pet_path, class: "btn btn-primary" %>
  </div>

  <table class="table table-striped">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Species</th>
        <th>Owner</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @pets.each do |pet| %>
        <tr>
          <td><%= pet.name %></td>
          <td><%= pet.species %></td>
          <td><%= pet.owner.last_name %></td>
          <td class="d-flex gap-2">
            <%= link_to "Show", pet, class: "btn btn-sm btn-info" %>
            <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-warning" %>
            <%= button_to "Delete", pet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>