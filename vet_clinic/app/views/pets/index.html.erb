<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Pets</h1>
    <% if policy(Pet.new(owner: current_user.owner)).new? %>
      <%= link_to "New Pet", new_pet_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <table class="table table-striped align-middle">
    <thead class="table-dark">
      <tr>
        <th style="width: 80px;">Photo</th> <%# Nueva columna %>
        <th>Name</th>
        <th>Species</th>
        <th>Owner</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @pets.each do |pet| %>
        <tr>
          <%# --- SECCIÓN DE MINIATURA (PASO A.7) --- %>
          <td>
            <% if pet.photo.attached? %>
              <%= image_tag pet.photo.variant(resize_to_fill: [60, 60]), class: "rounded shadow-sm border" %>
            <% else %>
              <div class="bg-light rounded d-flex align-items-center justify-content-center border" style="width: 60px; height: 60px; color: #adb5bd; font-size: 0.7rem; text-align: center;">
                No Photo
              </div>
            <% end %>
          </td>
          <%# --------------------------------------- %>
          
          <td><%= pet.name %></td>
          <td><%= pet.species %></td>
          <td><%= pet.owner.last_name %></td>
          <td>
            <div class="d-flex gap-2">
              <%= link_to "Show", pet, class: "btn btn-sm btn-info" %>
              <% if policy(pet).edit? %>
                <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-warning" %>
              <% end %>
              <% if policy(pet).destroy? %>
                <%= button_to "Delete", pet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
