<%= form_with(model: pet) do |f| %>
  <%= render 'shared/error_messages', object: pet %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :species, class: "form-label" %>
    <%= f.select :species, ['dog', 'cat', 'rabbit', 'bird', 'reptile', 'other'], {}, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :breed, class: "form-label" %>
    <%= f.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :date_of_birth, class: "form-label" %>
    <%= f.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :weight, class: "form-label" %>
    <%= f.number_field :weight, step: :any, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :owner_id, "Owner", class: "form-label" %>
    <%= f.collection_select :owner_id, Owner.all, :id, :last_name, { prompt: "Select an Owner" }, { class: "form-select" } %>
  </div>

  <%#foto %>
  <div class="mb-3">
    <%= f.label :photo, "Pet Photo", class: "form-label" %>
    
    <%# Si ya tiene una foto y estamos editando, mostramos la miniatura actual %>
    <% if pet.photo.attached? && pet.persisted? %>
      <div class="mb-2">
        <p class="small text-muted mb-1">Current photo:</p>
        <%= image_tag pet.photo, class: "img-thumbnail", style: "width: 100px; height: auto; display: block;" %>
      </div>
    <% end %>

    <%# El campo para subir el archivo %>
    <%= f.file_field :photo, class: "form-control" %>
    <div class="form-text">Max size 5MB (JPEG, PNG, WebP).</div>
  </div>
  <%# --------------------------------------- %>

  <div class="mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", pets_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>