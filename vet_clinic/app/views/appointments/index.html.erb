<div class="container mt-4">
  <h1 class="mb-4">Appointments</h1>

  <table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Vet</th>
        <th>Reason</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @appointments.each do |appointment| %>
        <tr>
          <td><%= appointment.date.strftime("%B %d, %Y - %H:%M") %></td>
          <td><%= appointment.pet.name %></td>
          <td>Dr(a). <%= appointment.vet.last_name %></td>
          <td><%= appointment.reason %></td>
          <td>
            <% # Aquí corregimos el problema del "Unknown" %>
            <% case appointment.status %>
            <% when 'scheduled' %>
              <span class="badge bg-primary">Scheduled</span>
            <% when 'in_progress' %>
              <span class="badge bg-warning text-dark">In Progress</span>
            <% when 'completed' %>
              <span class="badge bg-success">Completed</span>
            <% when 'cancelled' %>
              <span class="badge bg-danger">Cancelled</span>
            <% else %>
              <span class="badge bg-secondary"><%= appointment.status.to_s.humanize %></span>
            <% end %>
          </td>
          <td>
            <%= link_to "View Details", appointment_path(appointment), class: "btn btn-outline-info btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div> 