<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Appointments</h1>
    <% if policy(Appointment).new? %>
      <%= link_to "New Appointment", new_appointment_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <table class="table table-striped">
    <thead class="table-dark">
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @appointments.each do |appointment| %>
        <tr>
          <td><%= appointment.date.strftime("%B %d, %Y - %H:%M") %></td>
          <td><%= appointment.pet.name %></td>
          <td><span class="badge bg-secondary"><%= appointment.status.humanize %></span></td>
          <td class="d-flex gap-2">
            <%= link_to "Show", appointment, class: "btn btn-sm btn-info" %>
            <% if policy(appointment).edit? %>
              <%= link_to "Edit", edit_appointment_path(appointment), class: "btn btn-sm btn-warning" %>
            <% end %>
            <% if policy(appointment).destroy? %>
              <%= button_to "Delete", appointment, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
