<div class="container mt-4">
  <h1>Appointment Details</h1>
  <p><strong>Reason:</strong> <%= @appointment.reason %></p>
  
  <hr>
  
  <div class="d-flex justify-content-between align-items-center">
    <h3>Treatments</h3>
    <%= link_to "Add Treatment", new_appointment_treatment_path(@appointment), class: "btn btn-success btn-sm" %>
  </div>

  <table class="table mt-3">
    <thead>
      <tr>
        <th>Treatment</th>
        <th>Medication</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @appointment.treatments.each do |treatment| %>
        <tr>
          <td><%= treatment.name %></td>
          <td><%= treatment.medication %></td>
          <td class="d-flex gap-2">
            <%= link_to "Edit", edit_appointment_treatment_path(@appointment, treatment), class: "btn btn-sm btn-outline-warning" %>
            <%= button_to "Remove", [@appointment, treatment], method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= link_to "Edit Appointment", edit_appointment_path(@appointment), class: "btn btn-warning" %>
  <%= link_to "Back", appointments_path, class: "btn btn-secondary" %>
</div>
