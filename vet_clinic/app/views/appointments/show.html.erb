<div class="container mt-4">
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h1>Appointment Details</h1>
      <p><strong>Reason:</strong> <%= @appointment.reason %></p>
      <p><strong>Date:</strong> <%= @appointment.date.strftime("%d/%m/%Y %H:%M") %></p>
    </div>
  </div>
  
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Treatments</h3>
    <%= link_to "Add Treatment", new_appointment_treatment_path(@appointment), class: "btn btn-success" %>
  </div>

  <div class="table-responsive mb-4">
    <table class="table table-hover border">
      <thead class="table-light">
        <tr>
          <th>Treatment</th>
          <th>Medication / Dosage</th>
          <th>Clinical Notes</th> <%# Nueva columna %>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @appointment.treatments.each do |treatment| %>
          <tr>
            <td class="fw-bold"><%= treatment.name %></td>
            <td>
              <%= treatment.medication %> <br>
              <small class="text-muted"><%= treatment.dosage %></small>
            </td>
            <td>
              <%# B.2: Renderizado directo del contenido enriquecido %>
              <div class="trix-content small">
                <%= treatment.clinical_notes %>
              </div>
            </td>
            <td>
              <div class="d-flex gap-2">
                <%= link_to "Edit", edit_appointment_treatment_path(@appointment, treatment), class: "btn btn-sm btn-outline-warning" %>
                <%= button_to "Remove", [@appointment, treatment], method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%= link_to "Edit Appointment", edit_appointment_path(@appointment), class: "btn btn-warning" %>
    <%= link_to "Back", appointments_path, class: "btn btn-secondary" %>
  </div>
</div>