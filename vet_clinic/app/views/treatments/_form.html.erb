<% # Nota: Usamos un array [@appointment, treatment] para rutas anidadas %>
<%= form_with(model: [@appointment, treatment]) do |f| %>
  <%= render 'shared/error_messages', object: treatment %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :medication, class: "form-label" %>
    <%= f.text_field :medication, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :dosage, class: "form-label" %>
    <%= f.text_field :dosage, class: "form-control" %>
  </div>

  <%# --- SECCIÓN DE ACTION TEXT (PASO B.2) --- %>
  <div class="mb-3">
    <%= f.label :clinical_notes, "Clinical Notes", class: "form-label" %>
    <div class="bg-white text-dark"> <%# Esto ayuda a que el editor resalte mejor %>
      <%= f.rich_text_area :clinical_notes, placeholder: "Write detailed clinical observations here..." %>
    </div>
    <div class="form-text">You can use bold, lists, and headings.</div>
  </div>
  <%# ---------------------------------------- %>

  <div class="mb-3">
    <%= f.label :administered_at, class: "form-label" %>
    <%= f.datetime_field :administered_at, class: "form-control" %>
  </div>

  <div class="mt-4">
    <%= f.submit "Save Treatment", class: "btn btn-primary" %>
    <%= link_to "Cancel", appointment_path(@appointment), class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>